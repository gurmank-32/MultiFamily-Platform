# Streamlit Cloud Secrets Template
# 
# Copy this to Streamlit Cloud → Settings → Secrets
# OR create a local .streamlit/secrets.toml file (not committed to git)

# Required: OpenAI API Key for LLM features
OPENAI_API_KEY = "sk-your-openai-api-key-here"

# Optional: Email settings for alert notifications
SMTP_SERVER = "smtp.gmail.com"
SMTP_PORT = "587"
SMTP_EMAIL = "your_email@gmail.com"
SMTP_PASSWORD = "your_app_password"

# Note: Never commit actual secrets to git!
# This file is just a template.

